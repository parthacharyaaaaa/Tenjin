SECRET_KEY=
SIGNING_KEY=
PEM_ENCRYPTION_KEY=

SESSION_COOKIE_SECURE=0
JWKS_FILENAME=jwks.json
JWKS_CAP=3
APPLICAITON_ROOT=/api/v1

ACCESS_SCHEMA_FP=instance/access_schema.json
REFRESH_SCHEMA_FP=instance/refresh_schema.json

PORT=8080

RS_DOMAIN=resource_server:6090
RS_COMMUNICATION_PROTOCOL=http
RS_URL_PREFIX=/api/v1/

REDIS_CONFIG_FILENAME=redis_settings.toml

AUTH_WORKER_SYNC_REDIS_HOST=auth_server_synced_store
AUTH_WORKER_SYNC_REDIS_PORT=6379
AUTH_WORKER_SYNC_REDIS_DB=0

AUTH_WORKER_TOKEN_REDIS_HOST=auth_server_token_store
AUTH_WORKER_TOKEN_REDIS_PORT=6379
AUTH_WORKER_TOKEN_REDIS_DB=0

AUTH_WORKER_REDIS_USERNAME=auth_worker
AUTH_WORKER_REDIS_PASSWORD=123

AUTH_WORKER_POSTGRES_USERNAME=
AUTH_WORKER_POSTGRES_PASSWORD=

POSTGRES_HOST=auth_server_database
POSTGRES_PORT=5432
POSTGRES_DATABASE=auth_db

SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=10
SQLALCHEMY_POOL_RECYCLE=600
SQLALCHEMY_POOL_TIMEOUT=15
SQLALCHEMY_TRACK_MODIFICATIONS=0

SUSPICIOUS_LOOKBACK_TIME=1
MAX_ACTIVITY_LIMIT=5
ADMIN_SESSION_DURATION=900
MAX_VALID_KEYS=3
KEY_ROTATION_COOLDOWN=86400